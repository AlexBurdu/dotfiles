#!/usr/bin/env python3
"""Wrap markdown prose at a given width, leaving structure intact.

Reads markdown from stdin, wraps only prose paragraphs, and writes the
result to stdout. Tables, code blocks, headings, lists, blockquotes,
HTML tags, and link references are passed through unchanged.

Usage:
    cat README.md | mdwrap [-w WIDTH] [-p PATH]
    mdwrap -w 72 < README.md
    mdwrap -p README.md < README.md

Options:
    -w, --wrap WIDTH   Line width for prose wrapping (default: 80)
    -p, --path PATH    File path for .editorconfig lookup
    -h, --help         Show this help message

When -w is not given, mdwrap reads max_line_length for markdown from
.editorconfig files found by walking up from -p PATH. Falls back to 80.
"""

import configparser
import fnmatch
import os
import re
import sys
import textwrap

# Patterns for lines that are structural (not prose)
_STRUCTURAL = re.compile(
    r"^\s*\|"           # table row
    r"|^#{1,6}\s"       # heading
    r"|^\s*>"           # blockquote
    r"|^<"              # HTML tag
    r"|^\[.*\]:"        # link reference definition
    r"|^\s*$"           # blank line
)

_LIST_ITEM = re.compile(r"^(\s*)([-*+]|\d+[.)]) ")
_CODE_FENCE = re.compile(r"^(`{3,}|~{3,})")


def _parse_editorconfig(path):
    """Parse an .editorconfig file, handling the root preamble."""
    cfg = configparser.ConfigParser()
    with open(path) as f:
        content = f.read()
    # configparser needs a section header; prepend a fake one for the preamble
    cfg.read_string("[__preamble__]\n" + content, source=path)
    return cfg


def _editorconfig_width(path):
    """Read max_line_length for markdown from .editorconfig files."""
    if not path:
        return None
    path = os.path.abspath(path)
    directory = os.path.dirname(path) if os.path.isfile(path) else path
    while True:
        ec = os.path.join(directory, ".editorconfig")
        if os.path.isfile(ec):
            try:
                cfg = _parse_editorconfig(ec)
            except (configparser.Error, OSError):
                pass
            else:
                for section in cfg.sections():
                    if section == "__preamble__":
                        continue
                    if fnmatch.fnmatch("file.md", section) or fnmatch.fnmatch("README.md", section):
                        val = cfg.get(section, "max_line_length", fallback=None)
                        if val and val != "off":
                            try:
                                return int(val)
                            except ValueError:
                                pass
                is_root = cfg.getboolean("__preamble__", "root", fallback=False)
                if is_root:
                    break
        parent = os.path.dirname(directory)
        if parent == directory:
            break
        directory = parent
    return None


def mdwrap(text, width=80):
    """Wrap prose paragraphs in markdown text to *width* columns.

    Structural elements (tables, code blocks, headings, lists,
    blockquotes, HTML, link references) are returned unchanged.
    Consecutive prose lines are joined and reflowed with
    ``textwrap.fill``.
    """
    lines = text.split("\n")
    out = []
    in_code = False
    in_list = False
    prose_buf = []

    def flush_prose():
        if not prose_buf:
            return
        joined = " ".join(prose_buf)
        wrapped = textwrap.fill(
            joined, width=width, break_long_words=False, break_on_hyphens=False
        )
        out.append(wrapped)
        prose_buf.clear()

    for line in lines:
        if _CODE_FENCE.match(line):
            flush_prose()
            in_list = False
            in_code = not in_code
            out.append(line)
            continue

        if in_code:
            out.append(line)
            continue

        # Blank line: structural, ends list context
        if re.match(r"^\s*$", line):
            flush_prose()
            in_list = False
            out.append(line)
            continue

        # List item
        if _LIST_ITEM.match(line):
            flush_prose()
            in_list = True
            out.append(line)
            continue

        # List continuation: indented line while in a list
        if in_list and line[:1] == " ":
            flush_prose()
            out.append(line)
            continue

        # Other structural elements
        if _STRUCTURAL.match(line):
            flush_prose()
            in_list = False
            out.append(line)
            continue

        # Prose
        in_list = False
        prose_buf.append(line.strip())

    flush_prose()

    result = "\n".join(out)
    # Preserve trailing newline when the input had one
    if lines and lines[-1] == "" and not result.endswith("\n"):
        result += "\n"
    return result


def main():
    width = None
    filepath = None
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] in ("-h", "--help"):
            print(__doc__.strip())
            sys.exit(0)
        elif args[i] in ("-w", "--wrap") and i + 1 < len(args):
            width = int(args[i + 1])
            i += 2
            continue
        elif args[i] in ("-p", "--path") and i + 1 < len(args):
            filepath = args[i + 1]
            i += 2
            continue
        i += 1

    if width is None:
        width = _editorconfig_width(filepath) or 80

    sys.stdout.write(mdwrap(sys.stdin.read(), width=width))


if __name__ == "__main__":
    main()
