#!/usr/bin/env python3
"""Wrap markdown prose at a given width, leaving structure intact.

Reads markdown from stdin, wraps prose paragraphs, list items, and blockquotes,
while keeping headings, tables, and code blocks verbatim.

Usage:
    cat README.md | mdwrap [-w WIDTH] [-p PATH]
    mdwrap -w 72 < README.md
    mdwrap -p README.md < README.md

Options:
    -w, --wrap WIDTH   Line width for prose wrapping (default: 80)
    -p, --path PATH    File path for .editorconfig lookup
    -h, --help         Show this help message

When -w is not given, mdwrap reads max_line_length for markdown from
.editorconfig files found by walking up from -p PATH. Falls back to 80.
"""

import configparser
import fnmatch
import os
import re
import sys
import textwrap

# Patterns
_CODE_FENCE = re.compile(r"^(\s*)(`{3,}|~{3,})")
_HEADING = re.compile(r"^\s{0,3}#{1,6}\s")
_TABLE = re.compile(r"^\s*\|")
_LINK_REF = re.compile(r"^\[.*\]:")
_BLANK = re.compile(r"^\s*$")
_LIST_ITEM = re.compile(r"^(\s*)([-*+]|\d+[.)])(\s+)")
_BLOCKQUOTE = re.compile(r"^(\s*(?:> ?)+)")
_HTML_TAG = re.compile(r"^\s*<")


def _parse_editorconfig(path):
    """Parse an .editorconfig file, handling the root preamble."""
    cfg = configparser.ConfigParser()
    with open(path) as f:
        content = f.read()
    # configparser needs a section header; prepend a fake one for the preamble
    cfg.read_string("[__preamble__]\n" + content, source=path)
    return cfg


def _editorconfig_width(path):
    """Read max_line_length for markdown from .editorconfig files."""
    if not path:
        return None
    path = os.path.abspath(path)
    directory = os.path.dirname(path) if os.path.isfile(path) else path
    while True:
        ec = os.path.join(directory, ".editorconfig")
        if os.path.isfile(ec):
            try:
                cfg = _parse_editorconfig(ec)
            except (configparser.Error, OSError):
                pass
            else:
                for section in cfg.sections():
                    if section == "__preamble__":
                        continue
                    if fnmatch.fnmatch("file.md", section) or fnmatch.fnmatch("README.md", section):
                        val = cfg.get(section, "max_line_length", fallback=None)
                        if val and val != "off":
                            try:
                                return int(val)
                            except ValueError:
                                pass
                is_root = cfg.getboolean("__preamble__", "root", fallback=False)
                if is_root:
                    break
        parent = os.path.dirname(directory)
        if parent == directory:
            break
        directory = parent
    return None


def mdwrap(text, width=80):
    """Wrap markdown prose, lists, and blockquotes to *width* columns.

    Structural elements (tables, code blocks, headings, HTML, link references)
    are returned unchanged.
    """
    lines = text.split("\n")
    out = []

    in_code = False
    code_fence_marker = None
    code_fence_indent = ""

    buffer = []
    block_type = None  # 'prose', 'list', 'blockquote'

    # Block specific state
    list_indent = ""
    list_marker = ""
    bq_prefix = ""
    prose_indent = ""

    def flush():
        nonlocal buffer, block_type, list_indent, list_marker, bq_prefix, prose_indent
        if not buffer:
            return

        joined_text = " ".join(buffer)

        if block_type == "prose":
            wrapped = textwrap.fill(
                joined_text,
                width=width,
                initial_indent=prose_indent,
                subsequent_indent=prose_indent,
                break_long_words=False,
                break_on_hyphens=False,
            )
            out.append(wrapped)
        elif block_type == "list":
            initial = list_indent + list_marker
            subsequent = " " * len(initial)
            wrapped = textwrap.fill(
                joined_text,
                width=width,
                initial_indent=initial,
                subsequent_indent=subsequent,
                break_long_words=False,
                break_on_hyphens=False,
            )
            out.append(wrapped)
        elif block_type == "blockquote":
            wrapped = textwrap.fill(
                joined_text,
                width=width,
                initial_indent=bq_prefix,
                subsequent_indent=bq_prefix,
                break_long_words=False,
                break_on_hyphens=False,
            )
            out.append(wrapped)

        buffer = []
        block_type = None

    for line in lines:
        if in_code:
            # Check for closing fence with same indentation
            if line.strip() == code_fence_marker and line.startswith(code_fence_indent):
                in_code = False
                out.append(line)
            else:
                out.append(line)
            continue

        # Code fence start
        m = _CODE_FENCE.match(line)
        if m:
            flush()
            in_code = True
            code_fence_indent = m.group(1)
            code_fence_marker = m.group(2)
            out.append(line)
            continue

        # Structural / Verbatim / Blank
        if _BLANK.match(line):
            flush()
            out.append(line)
            continue

        if (
            _HEADING.match(line)
            or _TABLE.match(line)
            or _LINK_REF.match(line)
            or _HTML_TAG.match(line)
        ):
            flush()
            out.append(line)
            continue

        # List Item
        m = _LIST_ITEM.match(line)
        if m:
            flush()
            block_type = "list"
            list_indent = m.group(1)
            list_marker = m.group(2) + m.group(3)
            buffer.append(line[len(list_indent) + len(list_marker) :].strip())
            continue

        # Blockquote
        m = _BLOCKQUOTE.match(line)
        if m:
            new_prefix = m.group(1)
            content = line[len(new_prefix) :].strip()
            if not content:
                flush()
                out.append(line.rstrip())
                continue

            if block_type == "blockquote" and new_prefix == bq_prefix:
                buffer.append(content)
            else:
                flush()
                block_type = "blockquote"
                bq_prefix = new_prefix
                buffer.append(content)
            continue

        # Continuation of list?
        if block_type == "list":
            threshold = len(list_indent) + len(list_marker)
            if line.startswith(" " * threshold):
                buffer.append(line.strip())
                continue
            # Else fall through to prose

        # Prose
        if block_type != "prose":
            flush()
            block_type = "prose"
            m_ind = re.match(r"^(\s*)", line)
            prose_indent = m_ind.group(1)
            buffer.append(line.strip())
        else:
            buffer.append(line.strip())

    flush()

    result = "\n".join(out)
    if lines and lines[-1] == "" and not result.endswith("\n"):
        result += "\n"
    return result


def main():
    width = None
    filepath = None
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] in ("-h", "--help"):
            print(__doc__.strip())
            sys.exit(0)
        elif args[i] in ("-w", "--wrap") and i + 1 < len(args):
            width = int(args[i + 1])
            i += 2
            continue
        elif args[i] in ("-p", "--path") and i + 1 < len(args):
            filepath = args[i + 1]
            i += 2
            continue
        i += 1

    if width is None:
        width = _editorconfig_width(filepath) or 80

    sys.stdout.write(mdwrap(sys.stdin.read(), width=width))


if __name__ == "__main__":
    main()
